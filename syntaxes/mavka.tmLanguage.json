{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "袦邪胁泻邪",
  "patterns": [
    {
      "include": "#keywords"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#comments"
    }
  ],
  "repository": {
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.mavka",
          "match": "\\b(写褨褟|褋褌褉褍泻褌褍褉邪|锌械褉械斜褉邪褌懈|锌械褉械写邪褌懈|褟泻褖芯|褔械泻邪褌懈|胁蟹褟褌懈 屑芯写褍谢褜|胁蟹褟褌懈 锌邪泻|胁蟹褟褌懈 斜褨斜|胁蟹褟褌懈|写邪褌懈|褟泻|褦|胁械褉薪褍褌懈|褌褉懈胁邪谢邪|褨|邪斜芯|褋锌褉芯斜褍胁邪褌懈|蟹谢芯胁懈褌懈|褨薪邪泻褕械|胁锌邪褋褌懈|锌芯泻懈|屑芯写褍谢褜|褉褨胁薪芯|斜褨谢褜褕械|屑械薪褕械|泻褨薪械褑褜|薪械|褟|写褨泄褋薪械|薪械写褨泄褋薪械|锌褉械写屑械褌|胁谢邪褋薪邪)\\b"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.mavka",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.mavka",
          "match": "\\\\."
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.numeric.mavka",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.mavka",
          "match": ";;.*$"
        },
        {
          "name": "comment.block.mavka",
          "begin": ";\\*.*",
          "end": "\\*;"
        }
      ]
    }
  },
  "scopeName": "source.屑邪胁泻邪"
}